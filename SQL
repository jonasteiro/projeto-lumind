CREATE DATABASE projeto;
USE projeto;
CREATE TABLE cliente (
	id INT AUTO_INCREMENT PRIMARY KEY,
	nome VARCHAR(100),
	email VARCHAR(100),
	usuario VARCHAR(50),
	senha VARCHAR(50),
	instagram VARCHAR(100),
	ativo TINYINT(1) DEFAULT 1
);

